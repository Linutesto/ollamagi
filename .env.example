# OllamAGI Configuration
# Copy this file to .env and adjust for your setup.
# All values have sensible defaults — only set what you need to change.

# ── Paths ─────────────────────────────────────────────────────────────────────
# Directory where OllamAGI is installed (auto-detected if left blank)
# OLLAMAGI_DIR=/home/youruser/ollamagi

# Your home directory (used for bind-mounting into agent containers)
# OLLAMAGI_USER_HOME=/home/youruser

# Path to Hermes cognitive memory database (optional — works without Hermes)
# HERMES_DB=/home/youruser/.hermes/cognitive_memory.sqlite

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# Context window size — reduce if you hit memory limits
OLLAMA_CTX=65536

# ── Models ───────────────────────────────────────────────────────────────────
# Set to any models you have pulled in Ollama.
# Minimum viable setup: one general-purpose model for all roles.
MODEL_ORCHESTRATOR=qwen2.5:32b
MODEL_CODER=qwen2.5-coder:32b
MODEL_TOOLS=qwen2.5:32b
MODEL_ANALYSIS=qwen2.5:32b
MODEL_FAST=qwen2.5:7b
MODEL_EMBEDDINGS=mxbai-embed-large:latest

# ── Docker ───────────────────────────────────────────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock

# Container images used for agent execution
IMAGE_PYTHON=python:latest
IMAGE_GENERIC=debian:latest
IMAGE_PENTEST=vxcontrol/kali-linux:latest

# ── Agent SSH (optional) ──────────────────────────────────────────────────────
# Agents can SSH back to the host to run commands outside their container.
# Generate a dedicated key: ssh-keygen -t ed25519 -f ~/.ssh/ollamagi_agent
# Then add the public key to ~/.ssh/authorized_keys
SSH_KEY=~/.ssh/ollamagi_agent
SSH_HOST=172.17.0.1
SSH_USER=youruser

# ── Dashboard Hardware Display (cosmetic) ────────────────────────────────────
# These strings are shown in the System tab of the dashboard.
# HW_CPU=Ryzen 9 7950X 32t
# HW_RAM=64 GB DDR5
# HW_GPU=RTX 4090 24 GB
